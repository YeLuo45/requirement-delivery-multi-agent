{
  "name": "@rdma/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RDMA CLI — the main entry point for delivering requirements end-to-end.",
  "main": "./src/cli.ts",
  "types": "./src/cli.ts",
  "bin": {
    "rdma": "./src/cli.ts"
  },
  "exports": {
    "./run": "./src/run.ts",
    "./agent-provider": "./src/agent-provider.ts"
  },
  "scripts": {
    "start": "node --import tsx src/cli.ts",
    "rdma": "node --import tsx src/cli.ts",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@rdma/boss": "*",
    "@rdma/config": "*",
    "@rdma/core": "*",
    "@rdma/coordinator": "*",
    "@rdma/delivery-control": "*",
    "@rdma/designer": "*",
    "@rdma/dev": "*",
    "@rdma/llm": "*",
    "@rdma/observability": "*",
    "@rdma/persistence": "*",
    "@rdma/pm": "*",
    "@rdma/qa": "*",
    "@rdma/research": "*",
    "@rdma/realtime": "*"
  }
}
